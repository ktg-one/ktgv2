{
  "mcpServers": {
    "in-memoria": {
      "command": "npx",
      "args": ["-y", "in-memoria", "server"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "D:/projects/sites/ktgv2 (2)/ktgv2"
      ]
    },
    "mem0": {
      "command": "npx",
      "args": ["-y", "@mem0/mcp-server"],
      "env": {
        "MEM0_API_KEY": "",
        "MEM0_USER_ID": "kevinktg"
      }
    }
  }
}
